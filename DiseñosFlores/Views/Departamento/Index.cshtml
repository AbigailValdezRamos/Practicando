@model List<Departamento>

<h2 class="bg-danger">Departamentos</h2>

<a asp-controller ="Departamento" asp-action="Create">Nuevo</a>

<div class="container mt-4">
    <h2 class="mb-3">Departamentos</h2>

    <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
          
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdDepartamento</td>
                    <td>@item.NombreDepartamento</td>
                    <td class="text-center">
                        <a asp-controller="Departamento" asp-action="Edit" asp-route-id="@item.IdDepartamento" 
                           class="btn btn-sm btn-warning me-2">
                            Editar
                        </a>
                        <a asp-controller="Departamento" asp-action="Delete" asp-route-id="@item.IdDepartamento"
                           class="btn btn-sm btn-danger">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }

 
        </tbody>
    </table>
</div>