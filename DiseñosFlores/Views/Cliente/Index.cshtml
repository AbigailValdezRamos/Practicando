@model List<Cliente>

<h2 class="bg-danger">Clientes</h2>

<a asp-controller="Cliente" asp-action="Create">Nuevo</a>

<div class="container mt-4">

    <h2 class="mb-3">Clientes</h2>

    <div class="mb-3">
        <input type="text"
               id="txtRazonSocial"
               class="form-control"
               placeholder="Buscar por Razon Social y presione Enter" />
    </div>

    <div class="mb-3">
        <input type="text"
               id="txtDireccion"
               class="form-control"
               placeholder="Buscar por Direccion y presione Enter" />
    </div>

    <div class="mb-3">
        <select id="txtDepartamento" class="form-control">
            <option value="">-- Seleccione Departamento --</option>
            @foreach (var d in ViewBag.Departamentos)
            {
                <option value="@d.Value">@d.Text</option>
            }
        </select>
    </div>

    <div id="contenedorTabla">
        @await Html.PartialAsync("_TablaClientes", Model) <!--Vista parcial-->
    </div>

</div>

@section Scripts {
    <script>
        async function filtrar() {

            const razon = document.getElementById("txtRazonSocial").value;
            const direccion = document.getElementById("txtDireccion").value;
            const departamento = document.getElementById("txtDepartamento").value;

            const response = await fetch(`/Cliente/Index?razonSocial=${razon}&direccion=${direccion}&departamento=${departamento}`, {
                method: "GET",
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            });

            const html = await response.text();
            document.getElementById("contenedorTabla").innerHTML = html;
        }

        // ENTER en razón social
        document.getElementById("txtRazonSocial")
            .addEventListener("keydown", e => {
                if (e.key === "Enter") filtrar();
            });

        // ENTER en dirección
        document.getElementById("txtDireccion")
            .addEventListener("keydown", e => {
                if (e.key === "Enter") filtrar();
            });

        // ENTER en departamento
        document.getElementById("txtDepartamento")
            .addEventListener("change", () => {
            filtrar();
            });
    </script>
}